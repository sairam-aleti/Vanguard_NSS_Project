# Vanguard Logistics — SSH Hardening Configuration
# Install: sudo cp sshd_config /etc/ssh/sshd_config && sudo systemctl restart sshd

# Non-standard port (hint in robots.txt for CTF)
Port 58229

# Disable root login
PermitRootLogin no

# Key-based authentication only
PubkeyAuthentication yes
PasswordAuthentication no
ChallengeResponseAuthentication no
UsePAM no

# Connection limits
MaxAuthTries 3
MaxSessions 3
LoginGraceTime 30

# Restrict to specific users
AllowUsers vanguard

# Disable forwarding
X11Forwarding no
AllowTcpForwarding no
AllowAgentForwarding no

# Banner
Banner /etc/ssh/banner.txt

# Logging
LogLevel VERBOSE
SyslogFacility AUTH
